# SousVille 環境變數範例。複製為 .env 並填值。
#
# 兩個入口會讀同一份 .env：
#   1. app.py（Streamlit 前端，使用者用）
#   2. admin.py（管理後台，你 Joyce2 用）+ scripts/sync_from_cloud.py（每小時排程）

# ════════════════════════════════════════════════════════════
# 前端 app.py 用
# ════════════════════════════════════════════════════════════

# 後端 sufeidijia-api base URL（自架 / 測試環境改這個）
API_BASE_URL=https://api.joyceaimail.org

# 食物相片辨識（Gemini 2.0 Flash）；不設只是 AI 模式不能用，其他功能正常
GEMINI_API_KEY=

# LINE Login channel id（沒設前端會藏 LINE 登入按鈕，仍可用 Email 登入）
LINE_CHANNEL_ID=
LINE_LOGIN_REDIRECT_URI=


# ════════════════════════════════════════════════════════════
# admin.py + scripts/sync_from_cloud.py 用
# ════════════════════════════════════════════════════════════

# Supabase 專案 URL（不要加 /rest/v1 後綴）
SUPABASE_URL=https://your-project.supabase.co

# Supabase service_role key — bypass RLS，只應該存在於你 Joyce2 mac mini，
# **絕對不要** commit 到 repo / 貼進 .env.example、不要部署到 Render 上
# Streamlit Cloud 等公開機器
SUPABASE_SERVICE_KEY=

# 進入 admin.py 用的金鑰（隨便設一個夠長的字串）
ADMIN_SECRET=
