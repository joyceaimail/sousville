# SousVille Streamlit 前端環境變數範例。複製為 .env 並填值。
# 後端使用 sufeidijia-api (FastAPI + Supabase)，預設 https://api.joyceaimail.org

# ── 必填 ────────────────────────────────────────────────
# 後端 API base URL（自架 / 測試環境改這個）
API_BASE_URL=https://api.joyceaimail.org

# ── 選填 ────────────────────────────────────────────────
# 食物相片辨識（Gemini 2.0 Flash）；不設只是 AI 模式不能用，其他功能正常
GEMINI_API_KEY=

# LINE Login 用 channel id（沒設前端會藏 LINE 登入按鈕，仍可用 Email 登入）
LINE_CHANNEL_ID=
LINE_LOGIN_REDIRECT_URI=
